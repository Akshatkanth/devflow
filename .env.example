# Root example environment for local development and deployment
# Copy into your environment or a per-service .env file as needed.

NODE_ENV=development
NEXT_PUBLIC_API_URL=https://your-render-api.onrender.com
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/devflow
REDIS_URL=redis://localhost:6379
JWT_SECRET=change_me_to_a_long_random_secret_at_least_32_chars
CORS_ORIGIN=https://your-netlify-site.netlify.app
DEPLOYMENT_PREVIEW_URL=
ENABLE_DEPLOYMENT_WORKER=true
